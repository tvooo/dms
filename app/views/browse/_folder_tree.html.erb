<ul class="space-y-1">
  <% tree.keys.sort.each do |name| %>
    <% subtree = tree[name] %>
    <% path    = prefix.empty? ? name : "#{prefix}/#{name}" %>
    <% active  = @current_folder == path %>
    <li>
      <%= link_to browse_path(folder: path),
            class: "flex items-center gap-2 px-2 py-1.5 rounded text-sm #{active ? 'bg-blue-100 text-blue-900' : 'hover:bg-gray-100'}" do %>
        <%= lucide_icon :folder, css_class: "w-4 h-4 text-gray-400" %>
        <span class="truncate"><%= name %></span>
      <% end %>
      <% if subtree.any? %>
        <div class="pl-4 mt-1">
          <%= render "folder_tree", tree: subtree, prefix: path %>
        </div>
      <% end %>
    </li>
  <% end %>
</ul>
