<% content_for :title, "Tags" %>

<div class="p-6 max-w-2xl">
  <h1 class="text-2xl font-semibold mb-6">Tags</h1>

  <% if @roots.empty? %>
    <p class="text-sm text-gray-500">No tags yet. Tag a document from the Browse page to get started.</p>
  <% else %>
    <%= render "tags/tag_tree", tags: @roots %>
  <% end %>
</div>
