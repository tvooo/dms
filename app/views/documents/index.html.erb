<% content_for :title, "Home" %>

<div class="p-6">
  <h1 class="text-2xl font-semibold mb-6">Documents</h1>

  <% if @documents.empty? %>
    <p class="text-gray-500">No documents indexed yet.</p>
  <% else %>
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="border-b border-gray-300">
          <th class="py-2 pr-4 font-medium">Path</th>
          <th class="py-2 pr-4 font-medium">MIME type</th>
        </tr>
      </thead>
      <tbody>
        <% @documents.each do |document| %>
          <tr class="border-b border-gray-100">
            <td class="py-2 pr-4 font-mono text-sm"><%= document.path %></td>
            <td class="py-2 pr-4 text-sm text-gray-600"><%= document.mime_type %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>
