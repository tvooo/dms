<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for?(:title) ? "#{content_for(:title)} · DMS" : "DMS" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag :app %>
  </head>

  <body class="h-full flex bg-white text-gray-900">
    <aside class="w-56 shrink-0 border-r border-gray-200 bg-gray-50 flex flex-col">
      <div class="px-4 py-5 border-b border-gray-200">
        <h1 class="font-semibold tracking-tight">DMS</h1>
      </div>

      <nav class="flex-1 p-2 space-y-1">
        <%= nav_link "Home",   root_path,   icon: :house %>
        <%= nav_link "Browse", browse_path, icon: :folder_tree %>
        <%= nav_link "Tags",   tags_path,   icon: :tag %>
      </nav>

      <div class="px-4 py-1 text-xs text-gray-600">
        <div>Tools</div>
      </div>
      <nav class="flex-0 p-2 space-y-1">
        <%= nav_link "Duplicates",   "/duplicates",   icon: :house %>
      </nav>

      <div class="px-4 py-3 border-t border-gray-200 text-xs text-gray-600 space-y-2">
        <div><%= pluralize(Document.count, "document") %> indexed</div>
        <%= button_to "Scan now", scans_path,
              class: "w-full text-xs px-2 py-1 bg-gray-200 hover:bg-gray-300 rounded text-gray-800" %>
      </div>
    </aside>

    <main class="flex-1 min-w-0 overflow-auto">
      <% if flash.any? %>
        <div class="px-6 py-2 text-sm bg-blue-50 border-b border-blue-100 text-blue-900">
          <%= flash[:notice] || flash[:alert] %>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
